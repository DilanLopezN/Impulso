# Front-end (Expo) — apenas variáveis prefixadas com EXPO_PUBLIC_ são expostas
# ao bundle do cliente.
#
# Use este arquivo como referência: copie para `.env` (ou `.env.local`) e
# ajuste para o seu cenário. Para testar com ngrok ou IP real basta trocar
# os valores aqui — o app lê em tempo de build do Metro/Expo, então reinicie
# o packager (`npm start --clear`) após qualquer alteração.

# Base URL da API NestJS (módulos auth, users, sessions, ...).
# Exemplos:
#   http://localhost:3000              (web/iOS Simulator)
#   http://10.0.2.2:3000               (Android emulador → host)
#   http://192.168.0.10:3000           (LAN, dispositivo físico na mesma rede)
#   https://meu-tunel.ngrok-free.app   (túnel para teste externo)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Base URL dos workers Go (jobs assíncronos / cálculos pesados).
# Hoje os workers consomem fila e não expõem HTTP público; quando passarem
# a expor (ex.: endpoints de status / debug) configure aqui.
EXPO_PUBLIC_WORKERS_URL=http://localhost:4000
