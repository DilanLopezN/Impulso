# Voyage AI — embeddings (Anthropic's recommended embedding provider).
# https://docs.voyageai.com/
VOYAGE_API_KEY=your_voyage_api_key
VOYAGE_EMBED_MODEL=voyage-3

# Anthropic — used by the `ask_knowledge` MCP tool to synthesize answers
# from retrieved chunks.
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# pgvector connection (matches server/docker-compose.yml).
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5433
PGVECTOR_USER=knowledge
PGVECTOR_PASSWORD=knowledge
PGVECTOR_DATABASE=knowledge

# Folder scanned by the ingest script (relative to knowledge/).
KNOWLEDGE_DOCS_DIR=docs

# Chunking — token budget per chunk and overlap between adjacent chunks.
CHUNK_TOKENS=400
CHUNK_OVERLAP_TOKENS=60
